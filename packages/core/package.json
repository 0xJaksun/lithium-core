{
  "name": "@lithium-ai/core",
  "version": "0.0.4",
  "description": "Hierarchical versioned content store for structured context.",
  "keywords": [
    "hierarchical",
    "versioned",
    "storage",
    "ltree",
    "tree",
    "database",
    "structured-context",
    "context-store",
    "memory",
    "memory-store",
    "knowledge-store",
    "knowledge-graph",
    "content-versioning",
    "ai-context",
    "ai-memory",
    "mcp",
    "postgres"
  ],
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && tsc --emitDeclarationOnly --outDir dist",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run -c vitest.unit.config.ts --coverage"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.7",
    "tsup": "^8.5.1",
    "typescript": "6.0.3",
    "vitest": "4.1.5",
    "vitest-mock-extended": "^4.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
