{
  "name": "@lithium-ai/mcp",
  "version": "0.0.4",
  "description": "MCP server for structured hierarchical memory. Connect @lithium-ai/core to Claude and other AI tools.",
  "keywords": [
    "lithium",
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "claude",
    "claude-code",
    "ai-memory",
    "ai-tools",
    "ai-context",
    "structured-context",
    "hierarchical",
    "long-term-memory",
    "memory-layer",
    "llm",
    "developer-tools",
    "typescript"
  ],
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && tsc --emitDeclarationOnly --outDir dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@lithium-ai/core": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  },
  "engines": {
    "node": ">=20"
  }
}
