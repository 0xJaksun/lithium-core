{
  "name": "@lithium-ai/postgres",
  "version": "0.0.2",
  "description": "PostgreSQL adapter for @lithium-ai/core.",
  "keywords": [
    "lithium",
    "postgres",
    "postgresql",
    "ltree",
    "adapter",
    "hierarchical",
    "versioned",
    "storage",
    "database",
    "tree",
    "structured-context",
    "ai-memory"
  ],
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "src/migrations"],
  "scripts": {
    "build": "tsup && tsc --emitDeclarationOnly --outDir dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@lithium-ai/core": "workspace:*",
    "postgres": "^3.4.9",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  },
  "engines": {
    "node": ">=20"
  }
}
